
{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "baseUrl": "./src",

    "paths": {
      "@config/*": ["config/*"],
      "@modules/*": ["modules/*"],
      "@models/*": ["models/*"],
      "@middlewares/*": ["middlewares/*"],
      "@utils/*": ["utils/*"]
    },

    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ]
  },

  "include": ["src"]
}
